# --- tool init: fzf, zoxide (must run before any alias/completion that depends on them) ---
if [ -n "$ZSH_VERSION" ]; then
  command -v fzf >/dev/null 2>&1 && eval "$(fzf --zsh)"
  command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init zsh)"
elif [ -n "$BASH_VERSION" ]; then
  command -v fzf >/dev/null 2>&1 && eval "$(fzf --bash)"
  command -v zoxide >/dev/null 2>&1 && eval "$(zoxide init bash)"
fi
# fzf's Ctrl-T (fuzzy file insert) previews with bat when available
command -v bat >/dev/null 2>&1 && export FZF_CTRL_T_OPTS="--preview 'bat --color=always --style=numbers --line-range=:500 {}'"

